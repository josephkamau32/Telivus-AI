# Telivus AI — Environment Configuration
# Copy this file to .env and fill in your values.

# ─── Required ───────────────────────────────────────────────────────
# OpenAI (Required for AI features)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=2000

# Application
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ───────────────────────────────────────────────────────
# PostgreSQL (Required for production; SQLite fallback for local dev)
DATABASE_URL=postgresql://user:password@localhost/telivus_ai

# Redis (Optional; in-memory fallback if unavailable)
REDIS_URL=redis://localhost:6379

# ─── Server ─────────────────────────────────────────────────────────
SERVER_HOST=http://localhost
SERVER_NAME="Telivus AI Backend"

# CORS: comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]

# ─── Observability (Optional) ──────────────────────────────────────
# Langfuse: LLM tracing and observability (self-hostable, GDPR-safe)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sentry: Error tracking
SENTRY_DSN=

# ─── Vector Database ────────────────────────────────────────────────
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# ─── Advanced (Optional) ───────────────────────────────────────────
LOG_LEVEL=INFO
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Feature Flags
ENABLE_AI_AGENTS=True
ENABLE_RAG=True
ENABLE_VOICE_ANALYSIS=True

# Medical Knowledge Base
MEDICAL_KB_CHUNK_SIZE=1000
MEDICAL_KB_CHUNK_OVERLAP=200
MEDICAL_KB_TOP_K=5